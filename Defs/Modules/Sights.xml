<?xml version='1.0' encoding='utf-8'?>
<Defs>
  <ThingDef ParentName="CWF_Module">
    <defName>CWF_Module_Holoscope</defName>
    <label>holoscope</label>
    <graphicData>
      <texPath>CustomizeWeapon/Modules/Sight/Sight</texPath>
    </graphicData>
    <statBases>
      <WorkToMake>1500</WorkToMake>
    </statBases>
    <costList>
      <Steel>10</Steel>
      <ComponentIndustrial>1</ComponentIndustrial>
    </costList>
    <recipeMaker>
      <researchPrerequisite>PrecisionRifling</researchPrerequisite>
    </recipeMaker>
    <modExtensions>
      <li Class="CWF.TraitModuleExtension">
        <weaponTraitDef>CWF_Trait_Holoscope</weaponTraitDef>
        <part>Sight</part>
        <requiredWeaponTags>
          <li>CWF_AssaultRifle</li>
          <li>CWF_BoltActionRifle</li>
          <li>CWF_SniperRifle</li>
          <li>CWF_Shotgun</li>
          <li>CWF_SMG</li>
          <li>CWF_LMG</li>
          <li>CWF_Handgun</li>
        </requiredWeaponTags>
      </li>
    </modExtensions>
  </ThingDef>

