  <ThingDef ParentName="CWF_Module">
    <defName>CWF_Module_TacticalBarrel</defName>
    <label>tactical barrel</label>
    <graphicData>
      <texPath>CustomizeWeapon/Modules/Barrel/Barrel</texPath>
    </graphicData>
    <statBases>
      <WorkToMake>1500</WorkToMake>
    </statBases>
    <costList>
      <Steel>10</Steel>
      <ComponentIndustrial>1</ComponentIndustrial>
    </costList>
    <recipeMaker>
      <researchPrerequisite>Gunsmithing</researchPrerequisite>
    </recipeMaker>
    <modExtensions>
      <li Class="CWF.TraitModuleExtension">
        <weaponTraitDef>CWF_Trait_TacticalBarrel</weaponTraitDef>
        <part>Barrel</part>
        <conditionalPartModifiers>
          <li>
            <matcher>
              <weaponDefs>
                <li>Gun_LMG</li>
              </weaponDefs>
            </matcher>
            <enablesParts>
              <li>Underbarrel</li>
            </enablesParts>
          </li>
        </conditionalPartModifiers>
      </li>
    </modExtensions>
  </ThingDef>
</Defs>