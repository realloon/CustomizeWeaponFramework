<?xml version="1.0" encoding="utf-8"?>
<Defs>
  <!-- VerticalGrip -->
  <WeaponTraitDef ParentName="CWF_Trait">
    <defName>CWF_Trait_VerticalGrip</defName>
    <label>vertical grip</label>
    <description>A vertical foregrip that gives the shooter a steadier hold. It improves control and close-range accuracy.</description>
    <statFactors>
      <AccuracyTouch>1.1</AccuracyTouch>
      <AccuracyShort>1.1</AccuracyShort>
    </statFactors>
  </WeaponTraitDef>

  <!-- TriangularGrip -->
  <WeaponTraitDef ParentName="CWF_Trait">
    <defName>CWF_Trait_TriangularGrip</defName>
    <label>triangular grip</label>
    <description>An ergonomic foregrip that improves handling. It helps the shooter ready the weapon faster and steadies point-blank shots.</description>
    <statOffsets>
      <RangedWeapon_WarmupMultiplier>-0.05</RangedWeapon_WarmupMultiplier>
    </statOffsets>
    <statFactors>
      <AccuracyTouch>1.1</AccuracyTouch>
    </statFactors>
  </WeaponTraitDef>

  <!-- LaserSight -->
  <WeaponTraitDef ParentName="CWF_Trait">
    <defName>CWF_Trait_LaserSight</defName>
    <label>laser sight</label>
    <description>A laser sight that projects a visible dot onto the target. It speeds up aiming and improves accuracy at close to medium range.</description>
    <statOffsets>
      <RangedWeapon_WarmupMultiplier>-0.2</RangedWeapon_WarmupMultiplier>
    </statOffsets>
    <statFactors>
      <AccuracyTouch>1.1</AccuracyTouch>
      <AccuracyShort>1.1</AccuracyShort>
      <AccuracyMedium>1.1</AccuracyMedium>
    </statFactors>
  </WeaponTraitDef>

  <!-- GrenadeLauncher -->
  <WeaponTraitDef ParentName="CWF_Trait">
    <defName>CWF_Trait_GrenadeLauncher</defName>
    <label>grenade launcher</label>
    <description>This launcher fires a single high-explosive grenade for strong area damage. It must be reloaded after each shot.</description>
    <abilityProps>
      <abilityDef>CWF_Ability_LaunchFragGrenade</abilityDef>
      <maxCharges>1</maxCharges>
      <soundReload>Standard_Reload</soundReload>
      <chargeNoun>grenade</chargeNoun>
      <ammoDef>Steel</ammoDef>
      <ammoCountPerCharge>25</ammoCountPerCharge>
      <baseReloadTicks>60</baseReloadTicks>
    </abilityProps>
  </WeaponTraitDef>

  <!-- EMPLauncher -->
  <WeaponTraitDef ParentName="CWF_Trait">
    <defName>CWF_Trait_EMPLauncher</defName>
    <label>EMP cannon</label>
    <description>This launcher fires EMP shells that stun mechanoids and disable electronics. It can fire twice before reloading.</description>
    <abilityProps>
      <abilityDef>CWF_Ability_LaunchEMPShell</abilityDef>
      <maxCharges>2</maxCharges>
      <soundReload>Standard_Reload</soundReload>
      <chargeNoun>shell</chargeNoun>
      <ammoDef>Steel</ammoDef>
      <ammoCountPerCharge>15</ammoCountPerCharge>
      <baseReloadTicks>60</baseReloadTicks>
    </abilityProps>
  </WeaponTraitDef>

  <!-- SmokeLauncher -->
  <WeaponTraitDef ParentName="CWF_Trait">
    <defName>CWF_Trait_SmokeLauncher</defName>
    <label>smoke launcher</label>
    <description>This launcher fires smoke shells that create a dense cloud on impact. It can fire twice before reloading.</description>
    <abilityProps>
      <abilityDef>CWF_Ability_LaunchSmokeShell</abilityDef>
      <maxCharges>2</maxCharges>
      <soundReload>Standard_Reload</soundReload>
      <chargeNoun>shell</chargeNoun>
      <ammoDef>Steel</ammoDef>
      <ammoCountPerCharge>15</ammoCountPerCharge>
      <baseReloadTicks>60</baseReloadTicks>
    </abilityProps>
  </WeaponTraitDef>

  <!-- IncendiaryLauncher -->
  <WeaponTraitDef ParentName="CWF_Trait">
    <defName>CWF_Trait_IncendiaryLauncher</defName>
    <label>incendiary launcher</label>
    <description>This launcher fires a single incendiary shell that spreads fire on impact. It must be reloaded after each shot.</description>
    <abilityProps>
      <abilityDef>CWF_Ability_LaunchIncendiaryShell</abilityDef>
      <maxCharges>1</maxCharges>
      <soundReload>Standard_Reload</soundReload>
      <chargeNoun>shell</chargeNoun>
      <ammoDef>Chemfuel</ammoDef>
      <ammoCountPerCharge>15</ammoCountPerCharge>
      <baseReloadTicks>60</baseReloadTicks>
    </abilityProps>
  </WeaponTraitDef>
</Defs>
