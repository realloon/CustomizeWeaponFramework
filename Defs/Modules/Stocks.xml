<?xml version='1.0' encoding='utf-8'?>
<Defs>
  <ThingDef ParentName="CWF_Module">
    <defName>CWF_Module_ShortenedStock</defName>
    <label>shortened stock</label>
    <graphicData>
      <texPath>CustomizeWeapon/Modules/Stock/Stock</texPath>
    </graphicData>
    <statBases>
      <WorkToMake>1500</WorkToMake>
    </statBases>
    <costList>
      <Steel>10</Steel>
      <ComponentIndustrial>1</ComponentIndustrial>
    </costList>
    <recipeMaker>
      <researchPrerequisite>Gunsmithing</researchPrerequisite>
    </recipeMaker>
    <modExtensions>
      <li Class="CWF.TraitModuleExtension">
        <weaponTraitDef>CWF_Trait_ShortenedStock</weaponTraitDef>
        <part>Stock</part>
      </li>
    </modExtensions>
  </ThingDef>

